# Chemistry Lab Layout Generator - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- DeepSeek LLM API (required for equipment/layout/room generation) ---
CHEM_LAB_API_KEY=your-deepseek-api-key-here
CHEM_LAB_BASE_URL=https://api.deepseek.com

# --- Dashscope Image Generation API (required for layout-to-image) ---
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# --- Optional ---
# CHEM_LAB_IMAGE_DIR=output
